#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLAN_FILE="${SCRIPT_DIR}/apha-integration-bridge-boundary.jmx"
PROPERTIES_FILE="${SCRIPT_DIR}/environments/perf-test.properties"
RESULTS_DIR="${SCRIPT_DIR}/results"

usage() {
  cat <<'EOF'
Usage:
  ./bridge-perf gui [-- <extra-jmeter-args>]
  ./bridge-perf [-- <extra-jmeter-args>]
  ./bridge-perf help

Examples:
  ./bridge-perf gui
  ./bridge-perf
  ./bridge-perf -- -Jtarget.total.rps=30
  ./bridge-perf gui -- -Jauth.client_secret="$PERF_SECRET"
EOF
}

resolve_env_name() {
  printf '%s\n' "${ENV_NAME:-${environment:-${ENVIRONMENT:-perf-test}}}"
}

env_var_is_set() {
  local key="$1"
  env | LC_ALL=C grep -q "^${key}="
}

parse_env_file() {
  local env_file="$1"
  local line=""

  while IFS= read -r line || [[ -n "${line}" ]]; do
    line="${line%$'\r'}"

    [[ "${line}" =~ ^[[:space:]]*$ ]] && continue
    [[ "${line}" =~ ^[[:space:]]*# ]] && continue

    if [[ "${line}" =~ ^[[:space:]]*(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
      local key="${BASH_REMATCH[2]}"
      local value="${BASH_REMATCH[3]}"

      if [[ "${value}" =~ ^\".*\"$ ]] || [[ "${value}" =~ ^\'.*\'$ ]]; then
        value="${value:1:${#value}-2}"
      fi

      if ! env_var_is_set "${key}"; then
        export "${key}=${value}"
      fi
    fi
  done < "${env_file}"
}

load_local_env_files() {
  local env_file=""
  local env_files=(
    "${SCRIPT_DIR}/secrets.env"
    "${SCRIPT_DIR}/.env"
    "${SCRIPT_DIR}/.env.local"
    "${SCRIPT_DIR}/.envrc"
  )

  for env_file in "${env_files[@]}"; do
    if [[ -f "${env_file}" ]]; then
      parse_env_file "${env_file}"
    fi
  done
}

require_cmd() {
  local cmd="$1"
  if ! command -v "${cmd}" >/dev/null 2>&1; then
    echo "${cmd} is not installed or not on PATH" >&2
    exit 1
  fi
}

java_major_version() {
  java -version 2>&1 | awk -F '"' '/version/ {print $2}' | awk -F. '{print $1}'
}

auto_select_compatible_java() {
  local current_major=""
  if command -v java >/dev/null 2>&1; then
    current_major="$(java_major_version)"
    if [[ -n "${current_major}" ]] && (( current_major <= 21 )); then
      return 0
    fi
  fi

  if [[ -x /usr/libexec/java_home ]]; then
    local candidate_home=""
    for version in 21 17; do
      candidate_home="$(
        /usr/libexec/java_home -v "${version}" 2>/dev/null || true
      )"
      if [[ -n "${candidate_home}" ]]; then
        export JAVA_HOME="${candidate_home}"
        export PATH="${JAVA_HOME}/bin:${PATH}"
        return 0
      fi
    done
  fi
}

require_java_compatible() {
  local major=""
  major="$(java_major_version)"

  if [[ -z "${major}" ]]; then
    echo "Could not determine Java version. Set JAVA_HOME to Java 21 or 17." >&2
    exit 1
  fi

  if (( major > 21 )); then
    echo "Java ${major} detected. JMeter 5.6.3 in this repo should be run with Java 21 or 17." >&2
    exit 1
  fi
}

has_explicit_auth_client_secret() {
  local arg=""

  for arg in "$@"; do
    case "${arg}" in
      -Jauth.client_secret=*)
        return 0
        ;;
    esac
  done

  return 1
}

has_explicit_auth_client_id() {
  local arg=""

  for arg in "$@"; do
    case "${arg}" in
      -Jauth.client_id=*)
        return 0
        ;;
    esac
  done

  return 1
}

has_explicit_auth_host() {
  local arg=""

  for arg in "$@"; do
    case "${arg}" in
      -Jauth.host=*)
        return 0
        ;;
    esac
  done

  return 1
}

has_explicit_auth_bearer_token() {
  local arg=""

  for arg in "$@"; do
    case "${arg}" in
      -Jauth.bearer_token=*|-Jauth.mode=*)
        return 0
        ;;
    esac
  done

  return 1
}

secret_value_for_env() {
  local env_name="$1"

  case "${env_name}" in
    dev)
      printf '%s\n' "${DEV_SECRET:-}"
      ;;
    test)
      printf '%s\n' "${TEST_SECRET:-}"
      ;;
    perf|perf-test)
      printf '%s\n' "${PERF_SECRET:-}"
      ;;
    prod|preprod)
      printf '%s\n' "${PROD_SECRET:-}"
      ;;
  esac
}

normalise_cognito_domain() {
  local domain="$1"

  domain="${domain#http://}"
  domain="${domain#https://}"
  domain="${domain%%/*}"

  printf '%s\n' "${domain}"
}

collect_auth_args() {
  local env_name=""
  local bearer_token="${PERF_BEARER_TOKEN:-${AUTH_BEARER_TOKEN:-}}"
  local secret_value=""
  local client_id="${COGNITO_CLIENT_ID:-}"
  local cognito_domain="${COGNITO_DOMAIN:-}"

  env_name="$(resolve_env_name)"
  secret_value="${COGNITO_CLIENT_SECRET:-${CLIENT_SECRET:-$(secret_value_for_env "${env_name}")}}"

  if has_explicit_auth_client_secret "$@"; then
    secret_value=""
  fi

  if has_explicit_auth_bearer_token "$@"; then
    return 0
  fi

  if ! has_explicit_auth_client_id "$@" && [[ -n "${client_id}" ]]; then
    printf '%s\0' "-Jauth.client_id=${client_id}"
  fi

  if ! has_explicit_auth_host "$@" && [[ -n "${cognito_domain}" ]]; then
    printf '%s\0' "-Jauth.host=$(normalise_cognito_domain "${cognito_domain}")"
  fi

  if [[ -n "${bearer_token}" ]]; then
    printf '%s\0' "-Jauth.mode=bearer_token"
    printf '%s\0' "-Jauth.bearer_token=${bearer_token}"
    printf '%s\0' "-Jauth.credential_source=bearer_token_env"
    return 0
  fi

  if [[ -n "${secret_value}" ]]; then
    printf '%s\0' "-Jauth.client_secret=${secret_value}"
    if [[ -n "${COGNITO_CLIENT_SECRET:-}" ]]; then
      printf '%s\0' "-Jauth.credential_source=cognito_client_secret_override"
    elif [[ -n "${CLIENT_SECRET:-}" ]]; then
      printf '%s\0' "-Jauth.credential_source=client_secret_env"
    else
      printf '%s\0' "-Jauth.credential_source=${env_name}_secret"
    fi
  fi
}

collect_extra_args() {
  if [[ "${1:-}" == "--" ]]; then
    shift
  fi
  printf '%s\0' "$@"
}

run_gui() {
  mkdir -p "${RESULTS_DIR}"

  local args=(
    -t "${PLAN_FILE}"
    -q "${PROPERTIES_FILE}"
  )

  while IFS= read -r -d '' arg; do
    args+=("${arg}")
  done < <(collect_auth_args "$@" || true)

  while IFS= read -r -d '' arg; do
    args+=("${arg}")
  done < <(collect_extra_args "$@")

  exec jmeter "${args[@]}"
}

run_boundary() {
  mkdir -p "${RESULTS_DIR}"

  local args=(
    -n
    -t "${PLAN_FILE}"
    -q "${PROPERTIES_FILE}"
    "-Jresults.jtl=results/perf-test-boundary.jtl"
  )

  while IFS= read -r -d '' arg; do
    args+=("${arg}")
  done < <(collect_auth_args "$@" || true)

  while IFS= read -r -d '' arg; do
    args+=("${arg}")
  done < <(collect_extra_args "$@")

  exec jmeter "${args[@]}"
}

main() {
  local command="${1:-run}"
  if [[ "${command}" == "help" || "${command}" == "-h" || "${command}" == "--help" ]]; then
    usage
    return 0
  fi

  load_local_env_files
  require_cmd java
  require_cmd jmeter
  auto_select_compatible_java
  require_java_compatible

  if [[ "${command}" == "gui" ]]; then
    shift || true

    if [[ "${1:-}" == "perf-test" ]]; then
      shift || true
    elif [[ "${1:-}" == "dev" || "${1:-}" == "test" || "${1:-}" == "preprod" ]]; then
      echo "Only the perf-test profile is supported in this repo now." >&2
      exit 1
    fi

    run_gui "$@"
  fi

  if [[ "${command}" == "perf-test" ]]; then
    shift || true
  elif [[ "${command}" == "dev" || "${command}" == "test" || "${command}" == "preprod" ]]; then
    echo "Only the perf-test profile is supported in this repo now." >&2
    exit 1
  fi

  run_boundary "$@"
}

main "$@"
